+
+bool EffectsHandlerImpl::desktopExists(int row, int col) const
+{
+    return VirtualDesktopManager::self()->grid().at(QPoint(col, row)) != nullptr;
+}
+
+QPoint EffectsHandlerImpl::removingDesktopGridCoords() const
+{
+    return m_removingDesktopGridCoords;
+}
+
+int EffectsHandlerImpl::removingDesktop() const
+{
+    return m_removingDesktop;
+}
+
+void EffectsHandlerImpl::slotDesktopAboutToBeRemoved(KWin::VirtualDesktop *desktop)
+{
+    // Capture the desktop's grid position while the grid still reflects the
+    // pre-removal state (before renumbering and updateLayout in VDM).
+    m_removingDesktop = static_cast<int>(desktop->x11DesktopNumber());
+    m_removingDesktopGridCoords = VirtualDesktopManager::self()->grid().gridCoords(desktop);
+    Q_EMIT desktopAboutToBeRemoved(m_removingDesktop);
+}
